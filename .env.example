# ConvertX-extend Docker Compose 环境变量示例
# 使用方式：复制为 .env，然后按需修改。

# Web 服务端口，宿主机访问地址为 http://localhost:${CONVERTX_PORT}
CONVERTX_PORT=3000

# JWT 签名密钥。生产环境必须改成足够长且随机的字符串。
JWT_SECRET=please_change_this_to_a_long_random_secret

# 是否允许 HTTP 访问。
# 本地部署可设为 true；公网生产环境建议使用 HTTPS，并设为 false。
HTTP_ALLOWED=true

# 是否允许新用户注册。
# 设为 false 时，通常只保留首次初始化创建的账户。
ACCOUNT_REGISTRATION=false

# 是否允许未登录用户使用转换功能。
# 公网环境不建议开启。
ALLOW_UNAUTHENTICATED=false

# 自动清理文件的间隔小时数。
# 设置为 0 可关闭自动清理。
AUTO_DELETE_EVERY_N_HOURS=1

# 容器时区。
TZ=Asia/Shanghai

# 应用部署的子路径。
# 例如设置为 /convert 时，访问路径为 https://example.com/convert/
WEBROOT=

# 是否隐藏历史记录页面。
HIDE_HISTORY=false

# 未登录用户之间是否共享转换历史。
# 只有在 ALLOW_UNAUTHENTICATED=true 时才通常需要考虑。
UNAUTHENTICATED_USER_SHARING=false
